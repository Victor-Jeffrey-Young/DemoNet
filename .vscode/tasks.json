{
  "version": "2.0.0",
  "tasks": [
    // =========================================================
    // Docker 基础设施（MySQL / Redis / RabbitMQ）
    // =========================================================
    {
      "label": "🐳 Docker: 启动",
      "type": "shell",
      "command": "docker info >/dev/null 2>&1 || { echo '⛔ [前置条件] Docker 守护进程未运行'; echo '请先手动启动 Docker Desktop，等待托盘图标变绿后再重试。'; exit 1; } && docker compose up -d && echo '✅ Docker 容器已启动'",
      "windows": {
        "command": "docker info >nul 2>&1 || (echo ⛔ [前置条件] Docker 守护进程未运行 & echo 请先手动启动 Docker Desktop：双击桌面图标或从开始菜单启动 & echo 等待托盘中的 Docker 鲸鱼图标变绿（通常需要 30-60 秒）后再重试此任务。 & exit /b 1) & docker compose up -d && echo ✅ Docker 容器已启动",
        "options": {
          "shell": {
            "executable": "cmd.exe",
            "args": ["/d", "/c"]
          }
        }
      },
      "options": { "cwd": "${workspaceFolder}" },
      "presentation": { "reveal": "always", "panel": "dedicated", "clear": true, "showReuseMessage": false },
      "problemMatcher": []
    },
    {
      "label": "🐳 Docker: 停止",
      "type": "shell",
      "command": "docker compose down",
      "options": { "cwd": "${workspaceFolder}" },
      "presentation": { "reveal": "always", "panel": "dedicated" }
    },
    {
      "label": "🐳 Docker: 重启",
      "type": "shell",
      "command": "docker compose restart && echo '✅ 容器已重启'",
      "windows": {
        "command": "docker compose restart && echo ✅ 容器已重启",
        "options": {
          "shell": {
            "executable": "cmd.exe",
            "args": ["/d", "/c"]
          }
        }
      },
      "options": { "cwd": "${workspaceFolder}" },
      "presentation": { "reveal": "always", "panel": "dedicated", "clear": true }
    },
    {
      "label": "🐳 Docker: 查看日志",
      "type": "shell",
      "command": "docker compose logs -f --tail=100",
      "options": { "cwd": "${workspaceFolder}" },
      "presentation": { "reveal": "always", "panel": "new", "showReuseMessage": true },
      "isBackground": true,
      "problemMatcher": []
    },
    {
      "label": "🐳 Docker: 清理卷+重建",
      "type": "shell",
      "command": "docker compose down -v && docker compose up -d && echo '✅ 数据卷已清理并重建'",
      "windows": {
        "command": "docker compose down -v && docker compose up -d && echo ✅ 数据卷已清理并重建",
        "options": {
          "shell": {
            "executable": "cmd.exe",
            "args": ["/d", "/c"]
          }
        }
      },
      "options": { "cwd": "${workspaceFolder}" },
      "presentation": { "reveal": "always", "panel": "dedicated", "clear": true }
    },
    {
      "label": "🐳 Docker: 状态检查",
      "type": "shell",
      "command": "docker compose ps && echo && docker compose logs --tail=20",
      "windows": {
        "command": "docker compose ps && echo. && docker compose logs --tail=20",
        "options": {
          "shell": {
            "executable": "cmd.exe",
            "args": ["/d", "/c"]
          }
        }
      },
      "options": { "cwd": "${workspaceFolder}" },
      "presentation": { "reveal": "always", "panel": "dedicated", "clear": true }
    },

    // =========================================================
    // 后端：编译
    // =========================================================
    {
      "label": "🔧 后端: 编译",
      "type": "shell",
      "command": "mvn clean compile -q",
      "options": { "cwd": "${workspaceFolder}/backend" },
      "group": "build",
      "presentation": { "reveal": "always", "panel": "dedicated", "clear": true },
      "problemMatcher": [
        {
          "owner": "java",
          "fileLocation": ["relative", "${workspaceFolder}/backend"],
          "pattern": {
            "regexp": "\\[ERROR\\]\\s+(.*?):\\[(\\d+),(\\d+)\\]\\s+(.*)",
            "file": 1,
            "line": 2,
            "column": 3,
            "message": 4
          }
        }
      ]
    },
    {
      "label": "🔧 后端: 测试",
      "type": "shell",
      "command": "mvn test",
      "options": { "cwd": "${workspaceFolder}/backend" },
      "group": "test",
      "presentation": { "reveal": "always", "panel": "dedicated", "clear": true },
      "problemMatcher": [
        {
          "owner": "java",
          "fileLocation": ["relative", "${workspaceFolder}/backend"],
          "pattern": {
            "regexp": "\\[ERROR\\]\\s+(.*?):\\[(\\d+),(\\d+)\\]\\s+(.*)",
            "file": 1,
            "line": 2,
            "column": 3,
            "message": 4
          }
        }
      ]
    },
    {
      "label": "🔧 后端: 打包",
      "type": "shell",
      "command": "mvn clean package -DskipTests",
      "options": { "cwd": "${workspaceFolder}/backend" },
      "group": "build",
      "presentation": { "reveal": "always", "panel": "dedicated", "clear": true },
      "problemMatcher": []
    },
    {
      "label": "🔧 后端: 依赖更新检查",
      "type": "shell",
      "command": "mvn versions:display-dependency-updates versions:display-plugin-updates",
      "options": { "cwd": "${workspaceFolder}/backend" },
      "presentation": { "reveal": "always", "panel": "dedicated", "clear": true }
    },

    // =========================================================
    // 后端：开发模式（热重载 + Debug 端口 5005）
    // =========================================================
    {
      "label": "🔧 后端: 启动 Dev",
      "type": "shell",
      "command": "mvn spring-boot:run -Dspring-boot.run.jvmArguments=\"-agentlib:jdwp=transport=dt_socket,server=y,suspend=n,address=*:5005\"",
      "options": { "cwd": "${workspaceFolder}/backend" },
      "presentation": { "reveal": "always", "panel": "new", "clear": true, "showReuseMessage": true },
      "problemMatcher": {
        "owner": "java",
        "pattern": [{ "regexp": "^\\[ERROR\\] .*$" }],
        "background": {
          "activeOnStart": true,
          "beginsPattern": ".*spring-boot:run.*|Building.*",
          "endsPattern": "Started .*Application|Tomcat started on port"
        }
      },
      "isBackground": true
    },

    // =========================================================
    // 前端：开发模式（Vite HMR）
    // =========================================================
    {
      "label": "🎨 前端: 启动 Dev",
      "type": "shell",
      "command": "npm run dev",
      "options": { "cwd": "${workspaceFolder}/frontend" },
      "presentation": { "reveal": "always", "panel": "new", "clear": true, "showReuseMessage": true },
      "isBackground": true,
      "problemMatcher": {
        "pattern": {
          "regexp": "^$",
          "file": 1,
          "location": 2,
          "message": 3
        },
        "background": {
          "activeOnStart": true,
          "beginsPattern": "VITE",
          "endsPattern": "Local:.*http"
        }
      }
    },
    {
      "label": "🎨 前端: 构建生产版",
      "type": "shell",
      "command": "npm run build",
      "options": { "cwd": "${workspaceFolder}/frontend" },
      "group": "build",
      "presentation": { "reveal": "always", "panel": "dedicated", "clear": true },
      "problemMatcher": {
        "owner": "typescript",
        "fileLocation": ["relative", "${workspaceFolder}/frontend"],
        "pattern": {
          "regexp": "([^\\s].*?)\\((\\d+),(\\d+)\\):\\s+(error|warning)\\s+TS(\\d+):\\s+(.*)",
          "file": 1,
          "line": 2,
          "column": 3,
          "severity": 4,
          "code": 5,
          "message": 6
        }
      }
    },
    {
      "label": "🎨 前端: 类型检查",
      "type": "shell",
      "command": "npm run typecheck 2>&1 || npx vue-tsc --noEmit",
      "windows": {
        "command": "npm run typecheck 2>&1 || npx vue-tsc --noEmit",
        "options": {
          "shell": {
            "executable": "cmd.exe",
            "args": ["/d", "/c"]
          }
        }
      },
      "options": { "cwd": "${workspaceFolder}/frontend" },
      "group": "test",
      "presentation": { "reveal": "always", "panel": "dedicated", "clear": true },
      "problemMatcher": {
        "owner": "typescript",
        "fileLocation": ["relative", "${workspaceFolder}/frontend"],
        "pattern": {
          "regexp": "([^\\s].*?)\\((\\d+),(\\d+)\\):\\s+(error|warning)\\s+TS(\\d+):\\s+(.*)",
          "file": 1,
          "line": 2,
          "column": 3,
          "severity": 4,
          "code": 5,
          "message": 6
        }
      }
    },
    {
      "label": "🎨 前端: 代码规范检查",
      "type": "shell",
      "command": "npm run lint 2>&1 || npx eslint . --ext .vue,.js,.ts,.jsx,.tsx",
      "windows": {
        "command": "npm run lint 2>&1 || npx eslint . --ext .vue,.js,.ts,.jsx,.tsx",
        "options": {
          "shell": {
            "executable": "cmd.exe",
            "args": ["/d", "/c"]
          }
        }
      },
      "options": { "cwd": "${workspaceFolder}/frontend" },
      "group": "test",
      "presentation": { "reveal": "always", "panel": "dedicated", "clear": true },
      "problemMatcher": {
        "owner": "eslint",
        "fileLocation": ["relative", "${workspaceFolder}/frontend"],
        "pattern": {
          "regexp": "([^\\s].*?):(\\d+):(\\d+):\\s+(error|warning)\\s+(.*)",
          "file": 1,
          "line": 2,
          "column": 3,
          "severity": 4,
          "message": 5
        }
      }
    },
    {
      "label": "🎨 前端: 预览构建产物",
      "type": "shell",
      "command": "npm run preview",
      "options": { "cwd": "${workspaceFolder}/frontend" },
      "presentation": { "reveal": "always", "panel": "new", "clear": true, "showReuseMessage": true },
      "isBackground": true,
      "problemMatcher": []
    },

    // =========================================================
    // 一键启动：Docker → 后端 + 前端（自动分终端）
    // =========================================================
    {
      "label": "🚀 启动全部",
      "dependsOn": [
        "🐳 Docker: 启动",
        "🔧 后端: 启动 Dev",
        "🎨 前端: 启动 Dev"
      ],
      "dependsOrder": "sequence",
      "group": { "kind": "build", "isDefault": true },
      "presentation": { "reveal": "never" },
      "problemMatcher": []
    },
    {
      "label": "🔄 重启全部（含数据库清理）",
      "dependsOn": [
        "🐳 Docker: 清理卷+重建",
        "🔧 后端: 启动 Dev",
        "🎨 前端: 启动 Dev"
      ],
      "dependsOrder": "sequence",
      "presentation": { "reveal": "always", "panel": "dedicated" },
      "problemMatcher": []
    },
    {
      "label": "🛑 停止全部",
      "dependsOn": [
        "🔧 后端: 停止 Dev",
        "🎨 前端: 停止 Dev",
        "🐳 Docker: 停止"
      ],
      "dependsOrder": "sequence",
      "presentation": { "reveal": "always", "panel": "dedicated" },
      "problemMatcher": []
    },
    {
      "label": "🔧 后端: 停止 Dev",
      "type": "shell",
      "command": "lsof -ti :8080 | xargs kill -15 2>/dev/null || echo '无运行中的后端进程(8080)'",
      "windows": {
        "command": "for /f \"tokens=5\" %P in ('netstat -ano ^| findstr /R \":8080 .*LISTENING\"') do @taskkill /F /PID %P 2>nul || echo 无运行中的后端进程(8080)",
        "options": {
          "shell": {
            "executable": "cmd.exe",
            "args": ["/d", "/c"]
          }
        }
      },
      "options": { "cwd": "${workspaceFolder}/backend" },
      "presentation": { "reveal": "silent" },
      "problemMatcher": []
    },
    {
      "label": "🎨 前端: 停止 Dev",
      "type": "shell",
      "command": "lsof -ti :5173 | xargs kill -15 2>/dev/null || echo '无运行中的前端进程(5173)'",
      "windows": {
        "command": "for /f \"tokens=5\" %P in ('netstat -ano ^| findstr /R \":5173 .*LISTENING\"') do @taskkill /F /PID %P 2>nul || echo 无运行中的前端进程(5173)",
        "options": {
          "shell": {
            "executable": "cmd.exe",
            "args": ["/d", "/c"]
          }
        }
      },
      "options": { "cwd": "${workspaceFolder}/frontend" },
      "presentation": { "reveal": "silent" },
      "problemMatcher": []
    },
    {
      "label": "🗄️ 数据库: 执行迁移",
      "type": "shell",
      "command": "mvn flyway:migrate",
      "options": { "cwd": "${workspaceFolder}/backend" },
      "presentation": { "reveal": "always", "panel": "dedicated", "clear": true },
      "problemMatcher": []
    },
    {
      "label": "🗄️ 数据库: 重置并迁移",
      "type": "shell",
      "command": "mvn flyway:clean flyway:migrate",
      "options": { "cwd": "${workspaceFolder}/backend" },
      "presentation": { "reveal": "always", "panel": "dedicated", "clear": true },
      "problemMatcher": []
    },
    {
      "label": "🔍 环境检查",
      "type": "shell",
      "command": "docker version && echo && java -version 2>&1 | grep -i version && echo && node --version && npm --version && echo && mvn -v 2>&1 | grep -i \"Apache Maven\"",
      "windows": {
        "command": "docker version && echo. && java -version 2>&1 | findstr version && echo. && node --version && npm --version && echo. && mvn -v 2>&1 | findstr \"Apache Maven\"",
        "options": {
          "shell": {
            "executable": "cmd.exe",
            "args": ["/d", "/c"]
          }
        }
      },
      "options": { "cwd": "${workspaceFolder}" },
      "presentation": { "reveal": "always", "panel": "dedicated", "clear": true },
      "problemMatcher": []
    }
  ]
}
