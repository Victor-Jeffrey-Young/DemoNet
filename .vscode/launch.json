{
  "version": "0.2.0",
  "configurations": [
    // =========================================================
    // 后端：Attach（先 Ctrl+Shift+B 启动后端 Dev，再 F5 Attach）
    // =========================================================
    {
      "type": "java",
      "name": "🔌 后端: Attach (端口 5005)",
      "request": "attach",
      "hostName": "localhost",
      "port": 5005,
      "projectName": "DemoNet"
    },

    // =========================================================
    // 后端：直接启动（编译 → 运行，自带 debug）
    // =========================================================
    {
      "type": "java",
      "name": "▶️ 后端: 直接启动",
      "request": "launch",
      "mainClass": "com.example.demonet.DemoNetApplication",
      "projectName": "DemoNet",
      "cwd": "${workspaceFolder}/backend",
      "env": {
        "MYSQL_HOST": "localhost",
        "REDIS_HOST": "localhost",
        "RABBITMQ_HOST": "localhost"
      },
      "preLaunchTask": "🔧 后端: 编译"
    },

    // =========================================================
    // 前端：Edge 调试（先运行"🎨 前端: 启动 Dev"，再 F5）
    // =========================================================
    {
      "type": "msedge",
      "name": "🌐 前端: Edge",
      "request": "launch",
      "url": "http://localhost:5173",
      "webRoot": "${workspaceFolder}/frontend",
      "sourceMapPathOverrides": {
        "webpack:///./src/*": "${webRoot}/src/*"
      }
    },

    // =========================================================
    // 前端：Chrome 调试
    // =========================================================
    {
      "type": "chrome",
      "name": "🌐 前端: Chrome",
      "request": "launch",
      "url": "http://localhost:5173",
      "webRoot": "${workspaceFolder}/frontend",
      "sourceMapPathOverrides": {
        "webpack:///./src/*": "${webRoot}/src/*"
      }
    }
  ],

  // =========================================================
  // 组合：一键全栈（前提是前端 Dev 已手动启动）
  // =========================================================
  "compounds": [
    {
      "name": "🚀 全栈调试 (启动后端 + 前端浏览器)",
      "configurations": [
        "▶️ 后端: 直接启动",
        "🌐 前端: Edge"
      ],
      "preLaunchTask": "🐳 Docker: 启动",
      "stopAll": true
    }
  ]
}
